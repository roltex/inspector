# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Inspector"

# ---- Database ----
# Local development (zero-install, in-process WASM Postgres):
DATABASE_URL="file:./.pglite"
# Production / hosted Postgres:
# DATABASE_URL="postgres://USER:PASS@HOST:5432/DB"

# ---- Auth (Better Auth) ----
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-to-a-long-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# ---- Email (Resend, optional in dev) ----
RESEND_API_KEY=""
EMAIL_FROM="Inspector <no-reply@inspector.app>"

# ---- Stripe (leave empty in dev to disable billing UI) ----
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

STRIPE_PRICE_STARTER_MONTHLY=""
STRIPE_PRICE_STARTER_YEARLY=""
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""

# ---- Storage ----
STORAGE_DRIVER="local"     # local | s3
STORAGE_LOCAL_DIR=".uploads"

# ---- Web Push (VAPID) ----
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# ---- Platform admin ----
# Comma-separated list of emails that should be auto-promoted to super-admin
# the next time they sign up or sign in. Use to bootstrap the very first admin
# of a fresh deployment. After that, use `npm run admin:promote` instead.
SUPER_ADMIN_EMAILS=""
